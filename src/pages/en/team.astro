---
import { Image } from 'astro:assets';
import teamImg from '../../assets/Team.jpg';
import doraImg from '../../assets/Dora.jpg';
import nataliaImg from '../../assets/Natalia.jpg';
import meretImg from '../../assets/Meret.jpg';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineEntry from "../../components/team/TimelineEntry.astro";

const BRAND_COLOR = '#00008b';
---

<BaseLayout title="Team - studiofreunde" lang="en">
	<div class="min-h-screen bg-white px-6 md:px-12 lg:px-32 xl:px-60">
		<Header
			tagline="Minimal Interventions. Enduring Spaces."
			workLabel="Work"
			teamLabel="Team"
			contactLabel="Contact"
			currentLang="en"
		/>

		<!-- HERO SECTION -->
		<section class="pt-32 md:pt-36 pb-12 md:pb-20">
			<div class="w-full">
				<div class="max-w-4xl mx-auto">
					<div class="aspect-[3/2] overflow-hidden bg-gray-100">
						<Image
							src={teamImg}
							alt="studiofreunde Team"
							width={1200}
							height={800}
							loading="eager"
							class="w-full h-full object-cover"
						/>
					</div>
					<div class="flex flex-col md:flex-row justify-between mt-3 px-1 gap-2 md:gap-0">
						<span class="text-lg tracking-widest text-sm" style={`color: ${BRAND_COLOR}`}>
							Meret, Natalia, Dora
						</span>
						<span class="text-sm tracking-widest text-gray-400">
							(from left to right)
						</span>
					</div>
				</div>
			</div>
		</section>

		<!-- WHO WE ARE SECTION -->
		<section class="w-full max-w-4xl mx-auto mb-12 md:mb-20">
			<h2 class="text-2xl font-medium tracking-tight mb-6" style={`color: ${BRAND_COLOR}`}>
				WHO ARE WE?
			</h2>
			<div class="space-y-4 text-sm leading-loose tracking-wide text-justify" style={`color: ${BRAND_COLOR}`}>
				<p>
					studiofreunde is a collective of architects, planners, and consultants with combined experience in design, planning, and construction management from established architecture firms in Munich, Berlin, and Amsterdam.
				</p>
				<p>
					We oversee projects of various scales – from residential buildings to unique custom structures and from the initial goal-finding phase to completion.
				</p>
				<p>
					Our competencies complement each other. As a collective, we work flexibly and efficiently – assembling the right team for each task.
				</p>
			</div>
		</section>

		<!-- COLLABORATION ON EQUAL FOOTING SECTION -->
		<section class="w-full max-w-4xl mx-auto mb-16 md:mb-24">
			<h2 class="text-2xl font-medium tracking-tight mb-6" style={`color: ${BRAND_COLOR}`}>
				COLLABORATION ON EQUAL FOOTING
			</h2>
			<div class="space-y-4 text-sm leading-loose tracking-wide text-justify" style={`color: ${BRAND_COLOR}`}>
				<p>
					We develop projects from the concrete requirements of location, budget, and use. Clear concepts, precise planning, and careful implementation form the foundation of our work.
				</p>
				<p>
					We work in a structured, transparent, and solution-oriented manner. Clear processes and communication create security throughout all project phases.
				</p>
				<p>
					Our focus is on functional, appealing, and economically considered architecture. Where possible, we work with existing structures and utilize available resources. We make as few interventions as necessary and as many as sensible – with the goal of creating enduring and future-proof spaces.
				</p>
			</div>
		</section>

		<!-- TEAM MEMBERS SECTION -->
		<section class="w-full max-w-6xl mx-auto mb-12 md:mb-20">
			<!-- DÓRA NAGY -->
			<div class="mb-16 md:mb-24">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="md:col-span-2">
						<h3 class="text-xl font-medium tracking-tight mb-2" style={`color: ${BRAND_COLOR}`}>
							DÓRA NAGY <span class="text-gray-400">ARCHITECT</span>
						</h3>
						<div class="text-sm leading-relaxed tracking-wide space-y-3" style={`color: ${BRAND_COLOR}`}>
							<p class="font-medium">Member of the Bavarian Chamber of Architects</p>

                            <TimelineEntry
                                    timespan="Since 2025"
                                    title="Freelance"
                                    location="Member of the collective studiofreunde, Munich"
                            />

                            <TimelineEntry
                                    timespan="2024–2025"
                                    title="Meer Architekten, Munich"
                            />

                            <TimelineEntry
                                    timespan="2019–2024"
                                    title="ZAP Ziersch Architekten und Planer, Gräfelfing"
                            />

                            <TimelineEntry
                                    timespan="2017–2018"
                                    title="Independent practice, Munich"
                                    description="Design and submission planning as well as tendering and contracting for a studio house for the German-Hungarian writer Terezia Mora in collaboration with Hungarian architect Istvan Szava"
                            />

                            <TimelineEntry
                                    timespan="2015–2017"
                                    title="Master Architecture and Art"
                                    description="Thesis supervised by Prof. Carlo Baumschlager"
                                    location="Academy of Fine Arts Munich"
                            />

                            <TimelineEntry
                                    timespan="2012–2015"
                                    title="Assistant to Prof. Heike Hanada and Prof. Jan Kleihues, Berlin"
                            />

                            <TimelineEntry
                                    timespan="2010–2015"
                                    title="Bachelor Architecture and Urban Planning"
                                    description="Thesis supervised by Prof. Karl-Heinz Winkes"
                                    location="University of Applied Sciences Potsdam"
                            />
						</div>
					</div>
					<div class="flex items-start justify-center md:justify-end">
						<div class="w-full max-w-sm">
							<Image
								src={doraImg}
								alt="Dóra Nagy"
								width={400}
								height={600}
								class="w-full h-auto object-cover"
							/>
						</div>
					</div>
				</div>
			</div>

			<!-- NATALIA SIMONARSON -->
			<div class="mb-16 md:mb-24">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="md:col-span-2">
						<h3 class="text-xl font-medium tracking-tight mb-2" style={`color: ${BRAND_COLOR}`}>
							NATALIA SIMONARSON <span class="text-gray-400">PLANNER</span>
						</h3>
						<div class="text-sm leading-relaxed tracking-wide space-y-3" style={`color: ${BRAND_COLOR}`}>
                            <p class="font-medium">M.Sc. Architecture</p>
                            <p>Planner, BIM Expert</p>

                            <TimelineEntry
                                    timespan="Since 2026"
                                    title="Freelance"
                                    location="Member of the collective studiofreunde, Munich"
                            />

                            <TimelineEntry
                                    timespan="2025–2026"
                                    title="Meer Architekten, Munich"
                            />

                            <TimelineEntry
                                    timespan="2021–2022"
                                    title="J.MAYER.H Architekten, Berlin"
                            />

                            <TimelineEntry
                                    timespan="2021"
                                    title="Sascha Wurm Architektur, Munich"
                            />

                            <TimelineEntry
                                    timespan="2020"
                                    title="SeARCH architects, Amsterdam"
                            />

                            <TimelineEntry
                                    timespan="2022–2024"
                                    title="Master of Science Architecture, Urbanism and Building Sciences"
                                    description="Thesis supervised by Prof. Daniel Rosbottom"
                                    location="Delft University of Technology"
                            />

                            <TimelineEntry timespan="2017–2021" title="Bachelor of Arts Architecture"
                                           description="Thesis supervised by Prof. Stephen Bates and Prof. Bruno Krucker"
                                           location="Technical University of Munich" />
                            <TimelineEntry timespan="2018-2024" title="Scholar of the Heinrich Böll Foundation" />
                            <TimelineEntry timespan="2020–2021"title="Scholar of the Baumeister Academy" />
						</div>
					</div>
					<div class="flex items-start justify-center md:justify-end">
						<div class="w-full max-w-sm">
							<Image
								src={nataliaImg}
								alt="Natalia Simonarson"
								width={400}
								height={600}
								class="w-full h-auto object-cover"
							/>
						</div>
					</div>
				</div>
			</div>

			<!-- MERET HOFFMANN -->
			<div class="mb-12 md:mb-20">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="md:col-span-2">
						<h3 class="text-xl font-medium tracking-tight mb-2" style={`color: ${BRAND_COLOR}`}>
							MERET HOFFMANN <span class="text-gray-400">CONSULTANT</span>
						</h3>
						<div class="text-sm leading-relaxed tracking-wide space-y-3" style={`color: ${BRAND_COLOR}`}>
							<p class="font-medium">M.A. Architecture</p>
							<p>Consultant for construction supervision services</p>
						</div>
					</div>
					<div class="flex items-start justify-center md:justify-end">
						<div class="w-full max-w-sm">
							<Image
								src={meretImg}
								alt="Meret Hoffmann"
								width={400}
								height={600}
								class="w-full h-auto object-cover"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Footer
			impressumLabel="Imprint"
			impressumUrl="/en/impressum"
			copyrightText="studiofreunde. All rights reserved."
			photoCreditText="Photos"
		/>
	</div>
</BaseLayout>
