---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const BRAND_COLOR = '#00008b';
---

<BaseLayout title="Imprint - studiofreunde" lang="en">
	<div class="min-h-screen bg-white px-6 md:px-12 lg:px-32 xl:px-60">
		<Header
			tagline="Minimal Interventions. Enduring Spaces."
			workLabel="Work"
			contactLabel="Contact"
		/>

		<main class="pt-32 md:pt-36 pb-12 md:pb-20">
			<div class="max-w-4xl mx-auto">
				<div class="bg-white p-8 md:p-12" style={`color: ${BRAND_COLOR}`}>
					<h1 class="text-3xl font-bold mb-6">Imprint</h1>
					<div class="space-y-4 text-sm">
						<p><strong>Company Information</strong></p>
						<p>
							Studiofreunde<br />
							Eduard-Schmid-Str. 30<br />
							81541 München<br />
							Germany
						</p>
						<p>
							<strong>Contact:</strong><br />
							Email: <a href="mailto:info@studiofreunde.de">info@studiofreunde.de</a><br />
						</p>
						<p><em>Legal content to be added by site owner.</em></p>
					</div>
				</div>
			</div>
		</main>

		<Footer
			impressumLabel="Imprint"
			impressumUrl="/en/impressum"
			copyrightText="studiofreunde. All rights reserved."
			photoCreditText="Photos"
		/>
	</div>
</BaseLayout>
