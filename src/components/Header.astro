---
import InstagramIcon from './InstagramIcon.astro';
import LinkedInIcon from './LinkedInIcon.astro';

interface Props {
	tagline: string;
	workLabel: string;
	teamLabel: string;
	contactLabel: string;
	currentLang: 'de' | 'en';
}

const currentPath = Astro.url.pathname;

const { tagline, workLabel, teamLabel, contactLabel, currentLang } = Astro.props;
const otherLang = currentLang === 'de' ? 'en' : 'de';
const otherLangUrl = currentLang === 'de' ? `/en${currentPath}` : `${currentPath.replace('/en', '')}`;
const BRAND_COLOR = '#00008b';

---

<header class="fixed left-0 right-0 bg-white z-50">
	<div class="w-full px-6 md:px-12 lg:px-32 xl:px-60 py-6 md:py-12">
		<div class="flex flex-row items-center justify-center md:justify-between w-full relative">
			<!-- Mobile Menu Checkbox (hidden) -->
			<input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />

			<!-- Burger Menu Icon (Mobile Only) -->
			<label for="mobile-menu-toggle" class="md:hidden absolute right-0 cursor-pointer z-50 w-8 h-8 flex flex-col justify-center gap-1.5">
				<span class="burger-line block w-full h-0.5 transition-all duration-300" style={`background-color: ${BRAND_COLOR}`}></span>
				<span class="burger-line block w-full h-0.5 transition-all duration-300" style={`background-color: ${BRAND_COLOR}`}></span>
				<span class="burger-line block w-full h-0.5 transition-all duration-300" style={`background-color: ${BRAND_COLOR}`}></span>
			</label>

			<!-- Navigation (Left) - Hidden on mobile -->
			<nav class="hidden md:flex flex-1 justify-start gap-12">
				<a
					href={currentLang === 'de' ? "/#work" : "/en#work"}
					class="text-sm lowercase tracking-[0.2em] transition-opacity hover:opacity-70"
					style={`color: ${BRAND_COLOR}`}
				>
					{workLabel}
				</a>
				<a
					href={currentLang === 'de' ? '/team' : '/en/team'}
					class="text-sm lowercase tracking-[0.2em] transition-opacity hover:opacity-70"
					style={`color: ${BRAND_COLOR}`}
				>
					{teamLabel}
				</a>
				<a
					href="mailto:info@studiofreunde.de"
					class="text-sm lowercase tracking-[0.2em] transition-opacity hover:opacity-70"
					style={`color: ${BRAND_COLOR}`}
				>
					{contactLabel}
				</a>
			</nav>

			<!-- Logo (Center) - Always visible -->
			<div class="text-center">
				<h1
					class="text-3xl font-bold mb-1"
					style={`color: ${BRAND_COLOR}; letter-spacing: 1.5pt; font-family: agenda, sans-serif;`}
				>
                    <a href={currentLang == 'de' ? '/' : '/en'} style={`color: ${BRAND_COLOR}; letter-spacing: 1.5pt; font-family: agenda, sans-serif;`}>
					studiofreunde
                    </a>
				</h1>
				<p class="text-xs tracking-wide block" style={`color: ${BRAND_COLOR}`}>
					{tagline}
				</p>
			</div>

			<!-- Language Switcher & Social Icons (Right) - Hidden on mobile -->
			<div class="hidden md:flex flex-1 justify-end gap-4 items-center">
				<a
					href={otherLangUrl}
					class="text-xs uppercase tracking-wider transition-opacity hover:opacity-70 font-medium"
					style={`color: ${BRAND_COLOR}`}
					title={otherLang === 'de' ? 'Deutsch' : 'English'}
				>
					{otherLang}
				</a>
				<a
					href="https://www.linkedin.com/company/studiofreunde/"
					class="flex items-center justify-center w-6 h-6 rounded-sm border-2 transition-all hover:bg-opacity-10 hover:bg-blue-50"
					style={`border-color: ${BRAND_COLOR}; color: ${BRAND_COLOR}`}
				>
					<LinkedInIcon class="w-3 h-3" />
				</a>
				<a
					href="https://www.instagram.com/studio.freunde"
					class="flex items-center justify-center w-6 h-6 rounded-sm border-2 transition-all hover:bg-opacity-10 hover:bg-blue-50"
					style={`border-color: ${BRAND_COLOR}; color: ${BRAND_COLOR}`}
				>
					<InstagramIcon class="w-4 h-4" />
				</a>
			</div>
		</div>
	</div>

	<!-- Mobile Navigation Menu -->
	<nav id="mobile-nav" class="md:hidden mobile-nav absolute left-0 right-0 bg-white shadow-lg transition-all duration-300 overflow-hidden" style="top: 100%;">
		<div class="px-6 py-8 flex flex-col gap-6">
			<!-- Navigation Links -->
			<a
				href="#work"
				class="text-base lowercase tracking-[0.2em] transition-opacity hover:opacity-70 py-2"
				style={`color: ${BRAND_COLOR}`}
			>
				{workLabel}
			</a>
			<a
				href={currentLang === 'de' ? '/team' : '/en/team'}
				class="text-base lowercase tracking-[0.2em] transition-opacity hover:opacity-70 py-2"
				style={`color: ${BRAND_COLOR}`}
			>
				{teamLabel}
			</a>
			<a
				href="mailto:info@studiofreunde.de"
				class="text-base lowercase tracking-[0.2em] transition-opacity hover:opacity-70 py-2"
				style={`color: ${BRAND_COLOR}`}
			>
				{contactLabel}
			</a>

			<!-- Divider -->
			<div class="border-t pt-6" style={`border-color: ${BRAND_COLOR}20`}>
				<!-- Language Switcher -->
				<a
					href={otherLangUrl}
					class="text-sm uppercase tracking-wider transition-opacity hover:opacity-70 font-medium block py-2"
					style={`color: ${BRAND_COLOR}`}
					title={otherLang === 'de' ? 'Deutsch' : 'English'}
				>
					{otherLang === 'de' ? 'Deutsch' : 'English'}
				</a>
			</div>

			<!-- Social Icons -->
			<div class="flex gap-4 pt-2">
				<a
					href="https://www.linkedin.com/company/studiofreunde/"
					class="flex items-center justify-center w-8 h-8 rounded-sm border-2 transition-all hover:bg-opacity-10 hover:bg-blue-50"
					style={`border-color: ${BRAND_COLOR}; color: ${BRAND_COLOR}`}
					aria-label="LinkedIn"
				>
					<LinkedInIcon class="w-4 h-4" />
				</a>
				<a
					href="https://www.instagram.com/studio.freunde"
					class="flex items-center justify-center w-8 h-8 rounded-sm border-2 transition-all hover:bg-opacity-10 hover:bg-blue-50"
					style={`border-color: ${BRAND_COLOR}; color: ${BRAND_COLOR}`}
					aria-label="Instagram"
				>
					<InstagramIcon class="w-5 h-5" />
				</a>
			</div>
		</div>
	</nav>
</header>

<style>
	/* Burger menu animation to X */
	#mobile-menu-toggle:checked + label span:nth-child(1) {
		transform: translateY(8px) rotate(45deg);
	}

	#mobile-menu-toggle:checked + label span:nth-child(2) {
		opacity: 0;
	}

	#mobile-menu-toggle:checked + label span:nth-child(3) {
		transform: translateY(-8px) rotate(-45deg);
	}

	/* Hide mobile menu by default */
	#mobile-nav {
		transform: translateY(-100%);
		visibility: hidden;
		opacity: 0;
	}

	/* Show mobile menu when checkbox is checked */
	#mobile-menu-toggle:checked ~ #mobile-nav {
		transform: translateY(0);
		visibility: visible;
		opacity: 1;
	}

	/* Use general sibling combinator to target nav across parent boundaries */
	header:has(#mobile-menu-toggle:checked) #mobile-nav {
		transform: translateY(0);
		visibility: visible;
		opacity: 1;
	}
</style>

<script>
	// Close mobile menu when clicking on a link
	document.addEventListener('DOMContentLoaded', () => {
		const mobileNav = document.getElementById('mobile-nav');
		const menuToggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement;

		if (mobileNav && menuToggle) {
			const navLinks = mobileNav.querySelectorAll('a');
			navLinks.forEach(link => {
				link.addEventListener('click', () => {
					menuToggle.checked = false;
				});
			});
		}
	});
</script>
