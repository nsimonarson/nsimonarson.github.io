---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="3"
	stroke-linecap="round"
	stroke-linejoin="round"
	xmlns="http://www.w3.org/2000/svg"
	class={className}
	aria-hidden="true"
>
	<circle cx="12" cy="12" r="6"></circle>
	<circle cx="20" cy="4" r="1.5" fill="currentColor" stroke="none"></circle>
</svg>
