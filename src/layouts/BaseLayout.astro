---
import '../styles/global.css';

interface Props {
	title: string;
	lang: 'de' | 'en';
}

const { title, lang } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/icon.png" />
		<link rel="stylesheet" href="https://use.typekit.net/qub7tse.css" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
